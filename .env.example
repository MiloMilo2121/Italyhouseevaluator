# =========================================================================
# Valutatore Immobiliare Delfino — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# =========================================================================

# --- Supabase (unica source of truth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER prefix with NEXT_PUBLIC. Used by the API route (M4).
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) — usata in M4 ---
RESEND_API_KEY=
EMAIL_FROM="Delfino Real Estate <noreply@example.it>"
# Destinatario interno della scheda agente (M4)
AGENT_NOTIFICATION_EMAIL=

# --- Geocoding — usato in M5 ---
# Selettore provider dietro l'interfaccia GeocodingProvider: google | nominatim
GEOCODING_PROVIDER=google
GOOGLE_PLACES_API_KEY=

# --- Versioning del motore di valutazione (alimenta l'hash di idempotenza) ---
# Incrementare quando la matematica del motore cambia.
VALUATION_MODEL_VERSION=1

# --- V2: comparabili MCA (Apify) ---
# Abilita l'uso dei comparabili nel motore (default off ⇒ stima su base OMI).
COMPS_ENABLED=false
# Token Apify per ingestion annunci + webhook (pay-per-result). Gated.
APIFY_TOKEN=

# --- V2 Step 2: narrazione LLM (Claude) ---
# Chiave Anthropic per la relazione narrata (on-demand in dashboard). Senza
# chiave il sistema degrada: il report mostra solo i numeri deterministici.
ANTHROPIC_API_KEY=
# Modello di narrazione (opzionale). Default: claude-sonnet-4-6.
# Alternative: claude-haiku-4-5 (costo↓) · un modello Opus (qualità↑).
NARRATION_MODEL=
